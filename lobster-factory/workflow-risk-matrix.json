    },
    {
      "task_type": "notification_dispatch",
      "tool": "n8n",
      "allowed_envs": ["staging", "production"],
      "risk_level": "low",
      "approval_required": false,
      "rollback_required": false
    },
    {
      "task_type": "ci_validate",
      "tool": "github",
      "allowed_envs": ["staging", "production"],
      "risk_level": "medium",
      "approval_required": false,
      "rollback_required": false
    },
    {
      "task_type": "runtime_content_ops",
      "tool": "wordpress",
      "allowed_envs": ["staging", "production"],
      "risk_level": "medium",
      "approval_required": false,
      "rollback_required": false
    }
