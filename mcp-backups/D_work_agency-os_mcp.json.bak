{
  "mcpServers": {
    "airtable": {
      "command": "npx",
      "args": ["-y", "@loticdigital/airtable-mcp-server"],
      "env": {
        "AIRTABLE_API_KEY": "REPLACE_WITH_AIRTABLE_API_KEY"
      }
    },
    "wordpress": {
      "command": "npx",
      "args": ["-y", "@automattic/mcp-wordpress-remote@latest"],
      "env": {
        "WP_API_URL": "https://soulfulexpression.org/",
        "JWT_TOKEN": "REPLACE_WITH_WORDPRESS_JWT_TOKEN"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=iknutyjsntaqktnnzgxl&read_only=true&features=database,docs,development,debugging"
    },
    "replicate": {
      "command": "npx",
      "args": ["-y", "replicate-mcp"],
      "env": {
        "REPLICATE_API_TOKEN": "REPLACE_WITH_REPLICATE_API_TOKEN",
        "REPLICATE_WEBHOOK_SIGNING_KEY": "REPLACE_WITH_REPLICATE_WEBHOOK_SIGNING_KEY"
      }
    },
    "n8n": {
      "type": "http",
      "url": "https://jonjonesai.app.n8n.cloud/mcp-server/http",
      "headers": {
        "Authorization": "Bearer REPLACE_WITH_N8N_BEARER_TOKEN"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "chatgpt-fast": {
